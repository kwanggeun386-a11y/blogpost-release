{
  "name": "blog-writing-factory",
  "version": "5.1.0",
  "description": "블로그 글쓰기 보조 앱 - 멀티 AI 제공자 지원",
  "main": "server/index.js",
  "bin": "server/index.js",
  "scripts": {
    "install-all": "npm install && npm install --prefix client",
    "build": "npm run install-all && npm run build --prefix client",
    "server": "lsof -ti:3001 | xargs kill -9 2>/dev/null; nodemon server/index.js --watch server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/index.js",
    "pkg-build": "npm run build && npx pkg . --targets node22-win-x64 --output BlogFactory.exe"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/generative-ai": "^0.21.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "openai": "^4.67.0",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "debug": "^4.4.3"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/build/Release/node_sqlite3.node",
      "node_modules/sqlite3/lib/binding/**/*"
    ],
    "scripts": [
      "server/**/*.js"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "."
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0",
    "nodemon": "^3.1.14"
  }
}
